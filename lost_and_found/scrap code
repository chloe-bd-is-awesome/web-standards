/* The pinboard grid */

.pinboard {
  display: grid;
  grid-template-columns: repeat(4, 20%);
  gap: 5%;
  margin-top: 0%;
  margin-right: 2%;
  margin-left: 0%;
}
.pin {
  cursor: pointer;
  margin: 0;
}

/* By default: show images, hide descriptions */

.pin img {
  width: 20vh;
