    <!-- The container that switches layout -->
    <div class="grid icon-view" id="grid"></div>

/* Icon view — multi-column grid */
.grid.icon-view {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
  gap: 12px;
}

/* List view — single column */
.grid.list-view {
  display: grid;
  grid-template-columns: 1fr;
  gap: 8px;
}

/* Cards adjust their own layout based on parent class */
.card.icon-view {
  flex-direction: column;
  align-items: center;
}
.card.list-view {
  flex-direction: row;
  align-items: center;
}



